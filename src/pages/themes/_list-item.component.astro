---
import type { CollectionEntry } from 'astro:content';

import { Image } from 'astro:assets';

import { URL_PREFIX } from '../../shared/config';

interface Props {
  theme: CollectionEntry<'themes'>;
}
const { theme } = Astro.props;
const tagClassNames = theme.data.tags?.map((x) => `tag--${x}`).join(' ');
// Top div had `hidden` class
---

<div class={`group relative ${tagClassNames}`}>
  <div class="w-full overflow-hidden rounded-md group-hover:opacity-75">
    {
      theme.data.images?.[0] ? (
        <Image
          src={theme.data.images[0]}
          alt={theme.data.display}
          layout="constrained"
          widths={[400, 800, 1200]}
          sizes="(min-width: 1280px) 33vw, (min-width: 640px) 50vw, 100vw"
          transition:name={`theme-${theme.id}`}
        />
      ) : (
        <Image
          src={`https://placehold.co/1920x720?text=${theme.data.id}`}
          alt={theme.data.display}
          layout="constrained"
          width={1920}
          height={720}
          widths={[400, 800, 1200]}
          sizes="(min-width: 1280px) 33vw, (min-width: 640px) 50vw, 100vw"
        />
      )
    }
  </div>
  <div class="mt-4">
    <h3 class="text-sm text-gray-700 dark:text-gray-300">
      <a href={`${URL_PREFIX}${theme.collection}/${theme.id}`}>
        <span aria-hidden="true" class="absolute inset-0"></span>
        {theme.data.number && <span>ID#{theme.data.number} - </span>}
        {theme.data.id}
      </a>
    </h3>
    <p class="mt-1 text-sm text-gray-500">{theme.data.tags?.map((tag) => <span>#{tag} </span>)}</p>
  </div>
</div>
