---
import { Image } from 'astro:assets';
import { Code } from 'astro:components';
import { getEntry, render } from 'astro:content';

import { DOMAIN, SHIKI_THEMES, URL_PREFIX } from '../../shared/config';
import DelimitedLinks from '../../shared/delimited-links.component.astro';
import Layout from '../../shared/layout/base-layout.astro';
import {
  getEntryStaticPathsFromCollection,
  getUpdateReferences,
  getVendorSlug
} from '../../shared/utilities';

export async function getStaticPaths() {
  return await getEntryStaticPathsFromCollection('themes');
}

const { slug } = Astro.params;
if (!slug) throw new Error('Missing slug param');
const vendor = await getEntry('vendors', getVendorSlug(slug));
if (!vendor) throw new Error(`Missing vendor for slug: ${slug}`);
const entry = await getEntry('themes', slug);
if (!entry) throw new Error(`Missing themes entry: ${slug}`);
const since = await getUpdateReferences(entry.data.since);
const { Content } = await render(entry);

const pageTitle = entry.data.display || entry.data.id;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: pageTitle,
  url: new URL(`${URL_PREFIX}${entry.collection}/${entry.id}`, DOMAIN).href,
  about: `Theme for ${vendor.data.name} Android head units`,
  ...(entry.data.tags && { keywords: entry.data.tags.join(', ') })
};
---

<Layout title={pageTitle} jsonLd={jsonLd}>
  {
    entry.data.images?.length ? (
      entry.data.images.map((image, index) =>
        index === 0 ? (
          <div class="mb-5">
            <Image
              src={image}
              alt={`Screenshot of the ${entry.data.display || entry.data.id} theme`}
              layout="constrained"
              transition:name={`theme-${entry.id}`}
            />
          </div>
        ) : (
          <div class="mb-5">
            <Image
              src={image}
              alt={`Screenshot of the ${entry.data.display || entry.data.id} theme`}
              layout="constrained"
            />
          </div>
        )
      )
    ) : (
      <p class="prose dark:prose-invert mb-4">
        We don't have any screenshots of this theme yet. You can try to activate this theme, take
        some screenshots and contribute!
      </p>
    )
  }

  <div class="prose dark:prose-invert break-words">
    {
      entry.data.invalid && (
        <p>This theme appears to be invalid, so we do not recommend activating it.</p>
      )
    }

    {
      since.length > 0 && (
        <p>
          This theme was introduced in {since.length === 1 ? 'update' : 'updates'}
          <DelimitedLinks items={since} />, therefore it might not be available to activate on
          earlier firmwares.
        </p>
      )
    }

    {
      entry.data.client && (
        <p>
          This theme requires client <code>{entry.data.client}</code> set in your factory config
          file. See the <a href={`${URL_PREFIX}factory-settings/${vendor.id}`}>factory settings</a>{' '}
          section for more information.
        </p>
      )
    }

    <p>
      To make this theme available for selection in your factory settings, you might need to modify
      your <code>{vendor.data.factoryConfigFileName}</code> file. Find the <Code
        lang="xml"
        code={`<SupportUIList />`}
        inline
        themes={SHIKI_THEMES}
      /> section and add the following line: {
        entry.data.number ? (
          <Code
            lang="xml"
            code={`<Item id="${entry.data.number}" ui="${entry.data.id}" />`}
            inline
            themes={SHIKI_THEMES}
          />
        ) : (
          <Code
            lang="xml"
            code={`<Item id="1" name="${entry.data.id}" display="${entry.data.display}" />`}
            inline
            themes={SHIKI_THEMES}
          />
        )
      }. More information and examples can be found in <a
        href={`${URL_PREFIX}factory-settings/${vendor.id}`}>factory settings</a
      > section.
    </p>

    <Content />

    <a href={`${URL_PREFIX}${entry.collection}/${vendor.id}`} data-pagefind-ignore
      >Back to all {vendor.data.name} themes</a
    >
  </div>
</Layout>
