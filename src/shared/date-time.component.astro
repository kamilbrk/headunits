---
interface Props {
  date: string | Date;
}

const { date = new Date() } = Astro.props;
const iso = date instanceof Date ? date.toISOString() : date;
const formatted = new Date(iso).toLocaleString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<time datetime={iso}>{formatted}</time>
